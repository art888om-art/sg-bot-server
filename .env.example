# ─────────────────────────────────────────────
# AutoCRM — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────

# Telegram bot
BOT_TOKEN=
# webhook | polling. Use 'webhook' in production.
BOT_MODE=polling
# Public HTTPS base URL of the service (Render gives you one).
# Required when BOT_MODE=webhook.
WEBHOOK_BASE_URL=
# Secret path segment + X-Telegram-Bot-Api-Secret-Token. Generate with `openssl rand -hex 32`.
WEBHOOK_SECRET=

# Google Sheets
GOOGLE_SHEET_URL=
# Path to service-account JSON file with Sheets access.
# On Render use a Secret File mounted at /etc/secrets/google_key.json.
GOOGLE_CREDENTIALS_FILE=./google_key.json

# Authorization
# >=32 random bytes. Generate with `openssl rand -hex 32`.
JWT_SECRET=
JWT_TTL_DAYS=7
# Comma-separated Telegram IDs of owners (admins). They are auto-registered with role=owner.
OWNER_IDS=

# Web server
HOST=0.0.0.0
PORT=8000
# 'production' enables Secure cookies, disables debug.
ENV=development
LOG_LEVEL=INFO

# External integrations (optional)
NOVA_POSHTA_API_KEY=

# Cache
SHEETS_CACHE_TTL_SECONDS=30
